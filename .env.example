APP_NAME=FluxConvert
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120

